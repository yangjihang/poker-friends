# ===== 必须改 =====
# 用 `openssl rand -hex 32` 生成一个
JWT_SECRET=please-change-me-to-a-long-random-string

# ===== 数据库 =====
# 方案 A：用 compose 自带的 db 服务（开发/小规模）
DATABASE_URL=postgresql+asyncpg://poker:poker@db:5432/poker
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker
POSTGRES_DB=poker

# 方案 B：用腾讯云 CDB（生产推荐）—— 删掉上面 4 行，把下面这行打开并改成真实连接串
# DATABASE_URL=postgresql+asyncpg://user:pass@cdb-xxxxx.sql.tencentcdb.com:5432/poker

# ===== CORS =====
# "*" 只适合同源部署（前端经 nginx 反代后端）。
# 如果前后端不同域，填逗号分隔的域名白名单，如：https://poker.example.com,https://www.poker.example.com
CORS_ORIGINS=*

# ===== Web 对外端口 =====
WEB_PORT=8080

# ===== 业务参数 =====
# 新用户注册奖励（筹码单位，默认 20000）
REGISTER_BONUS=20000

# 启动时自动创建的管理员（二者都填才生效；已存在则只确保 is_admin=true，不覆盖密码）
# ！！！生产部署前必须把 ADMIN_PASSWORD 改成强密码，下面的默认值只是占位
ADMIN_USERNAME=admin
ADMIN_PASSWORD=PLEASE_CHANGE_ME_to_strong_password
ADMIN_DISPLAY_NAME=Admin

# /metrics 访问令牌：生产**必填**，Prometheus 抓取时带 Authorization: Bearer <token>
# 留空则 /metrics 公开（仅适合 dev）
METRICS_TOKEN=
